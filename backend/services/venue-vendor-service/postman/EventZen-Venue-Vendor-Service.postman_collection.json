              "raw": "{\n  \"venueName\": \"Grand Convention Center\",\n  \"description\": \"Large convention center perfect for corporate events and conferences\",\n  \"address\": {\n    \"street\": \"123 Convention Ave\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"zipCode\": \"10001\",\n    \"country\": \"USA\"\n  },\n  \"longitude\": -74.0059,\n  \"latitude\": 40.7128,\n  \"capacity\": 1000,\n  \"pricePerDay\": 5000,\n  \"halls\": [\n    {\n      \"hallName\": \"Main Hall\",\n      \"capacity\": 800\n    },\n    {\n      \"hallName\": \"Conference Room A\",\n      \"capacity\": 100\n    }\n  ],\n  \"amenities\": [\"WiFi\", \"Sound System\", \"Projector\", \"Catering Kitchen\"],\n  \"contactInfo\": {\n    \"email\": \"contact@grandconvention.com\",\n    \"phone\": \"+1-555-0123\"\n  }\n}"
