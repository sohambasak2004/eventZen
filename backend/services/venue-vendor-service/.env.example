# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/eventzen_venue_vendor
MONGODB_TEST_URI=mongodb://localhost:27017/eventzen_venue_vendor_test

# JWT Configuration (should match auth service)
JWT_PUBLIC_KEY_PATH=../auth-service/public.pem
JWT_ALGORITHM=RS256

# Cors Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Geospatial Configuration
DEFAULT_SEARCH_RADIUS_KM=50
MAX_SEARCH_RADIUS_KM=200

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# External Services
AUTH_SERVICE_URL=http://localhost:8081
EVENT_SERVICE_URL=http://localhost:3002

# Notification Service (if applicable)
NOTIFICATION_SERVICE_URL=http://localhost:3003

# File Upload (if needed for venue images)
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=5242880
